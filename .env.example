SLACK_TOKEN=xoxp-your-user-token-here
# Required when SLACK_TOKEN is an xoxc browser-session token: the value of the
# `d` cookie from your authenticated Slack web session. Without it,
# files.slack.com redirects authed image requests to the workspace login page.
# SLACK_COOKIE=xoxd-...
# Optional: filter to a specific workspace.
# SLACK_TEAM=T01234567
# Optional: override config file location.
# WLSLACK_CONFIG=/path/to/config.toml
